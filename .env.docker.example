# Copie para .env.docker e preencha. NUNCA commite o .env.docker.
APP_NAME="Iwori Agenda"
APP_ENV=production
# Gere com: php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080
# Porta publicada em 127.0.0.1 pelo compose.prod.yaml
APP_PORT=8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=iwori_agenda
DB_USERNAME=iwori
DB_PASSWORD=defina_uma_senha_forte

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
# true quando o site estiver atrás de HTTPS (recomendado em produção)
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="agenda@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Envio real via Gmail: gere uma senha de app (conta com 2FA) e use:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=seuemail@gmail.com
# MAIL_PASSWORD=senha_de_app_de_16_caracteres
# MAIL_FROM_ADDRESS=seuemail@gmail.com

# Sincronização com o Google Calendar (OAuth 2.0)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
